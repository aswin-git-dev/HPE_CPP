APP_NAME=audit-service
ENV=dev
LOG_LEVEL=INFO

HOST=0.0.0.0
PORT=8005

# Namespace filtering
# ALLOWED_NAMESPACES=default,ecommerce
IGNORED_NAMESPACES=kube-system,kube-public,kube-node-lease

# Retention controls
STORE_RAW_EVENT=true
RAW_EVENT_MAX_BYTES=64000
# RETAINED_FIELDS=event_id,timestamp,source_type,namespace,service_name,severity,event_type,message,tags,status_code

# Optional OpenSearch (not used by /control-plane/ui — that reads the in-memory event store only).
# OPENSEARCH_ENABLED=true
# OPENSEARCH_URL=http://opensearch:9200
# OPENSEARCH_USER=admin
# OPENSEARCH_PASSWORD=admin
# OPENSEARCH_INDEX=audit-events
# OPENSEARCH_VERIFY_CERTS=false
# OPENSEARCH_TIMEOUT_S=10
# OPENSEARCH_MAX_RETRIES=3
# OPENSEARCH_EVENTS_TTL_DAYS=0
# OPENSEARCH_PURGE_INTERVAL_HOURS=6
# In-memory monitor store time cap (seconds). 0 = maxlen only.
EVENT_STORE_TTL_SECONDS=0

# Observability
ENABLE_METRICS=true

