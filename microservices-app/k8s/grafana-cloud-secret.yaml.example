# Copy to grafana-cloud-secret.yaml (gitignored) OR:
#   copy .env.example .env   (edit values)
#   powershell -File apply-grafana-cloud-secret.ps1
#
# Vector appends /loki/api/v1/push — use BASE host URL only in LOKI_URL.apiVersion: v1
kind: Secret
metadata:
  name: grafana-cloud-loki
  namespace: ecommerce
type: Opaque
stringData:
# Vector appends /loki/api/v1/push automatically — use BASE host URL only.
  LOKI_URL: "https://logs-prod-XXX.grafana.net"
  LOKI_USERNAME: "YOUR_INSTANCE_ID"
  LOKI_PASSWORD: "glc_YOUR_GRAFANA_CLOUD_TOKEN"
