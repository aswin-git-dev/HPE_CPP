  "links": [],
  "panels": [
    {
      "title": "Audit Events Over Time",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 0 },
      "datasource": { "type": "loki", "uid": "grafanacloud-logs" },
      "targets": [
        {
          "expr": "sum(count_over_time({source_type=\"k8s_audit\"} [5m])) by (verb)",
          "legendFormat": "{{verb}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" } }
      }
    },
    {
      "title": "Audit Events by Verb",
      "type": "piechart",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 8 },
      "datasource": { "type": "loki", "uid": "grafanacloud-logs" },
      "targets": [
        {
          "expr": "sum(count_over_time({source_type=\"k8s_audit\"} [$__range])) by (verb)",
          "legendFormat": "{{verb}}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Audit Events by Resource",
      "type": "piechart",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 8 },
      "datasource": { "type": "loki", "uid": "grafanacloud-logs" },
      "targets": [
        {
          "expr": "sum(count_over_time({source_type=\"k8s_audit\"} [$__range])) by (resource)",
          "legendFormat": "{{resource}}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Error Responses (4xx/5xx)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 8 },
      "datasource": { "type": "loki", "uid": "grafanacloud-logs" },
      "targets": [
        {
          "expr": "count_over_time({source_type=\"k8s_audit\"} |= \"Failure\" [5m])",
          "legendFormat": "Failures",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Recent Audit Events (Live Tail)",
      "type": "logs",
      "gridPos": { "h": 12, "w": 24, "x": 0, "y": 16 },
      "datasource": { "type": "loki", "uid": "grafanacloud-logs" },
      "targets": [
        {
          "expr": "{source_type=\"k8s_audit\"}",
          "refId": "A"
        }
      ],
      "options": {
        "showTime": true,
