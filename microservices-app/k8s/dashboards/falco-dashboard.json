{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "Total Falco Alerts",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "datasource": { "type": "loki", "uid": "grafanacloud-logs" },
      "targets": [
        {
          "expr": "sum(count_over_time({source_type=\"falco\"} [$__range]))",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Critical & Emergency Alerts",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "datasource": { "type": "loki", "uid": "grafanacloud-logs" },
      "targets": [
        {
          "expr": "sum(count_over_time({source_type=\"falco\"} | json | priority=~\"(?i)Critical|Emergency|Alert\" [$__range]))",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Notice Alerts",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "datasource": { "type": "loki", "uid": "grafanacloud-logs" },
      "targets": [
        {
          "expr": "sum(count_over_time({source_type=\"falco\"} | json | priority=~\"(?i)Notice|Info|Informational|Debug\" [$__range]))",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Falco Alert Rate by Priority (Over Time)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 4 },
      "datasource": { "type": "loki", "uid": "grafanacloud-logs" },
      "targets": [
        {
          "expr": "sum(count_over_time({source_type=\"falco\"} | json [$__interval])) by (priority)",
          "legendFormat": "{{priority}}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Alerts by Priority — Distribution",
      "type": "piechart",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 12 },
      "datasource": { "type": "loki", "uid": "grafanacloud-logs" },
      "targets": [
        {
          "expr": "sum(count_over_time({source_type=\"falco\"} | json [$__range])) by (priority)",
          "legendFormat": "{{priority}}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Top Triggered Rules",
      "type": "barchart",
      "gridPos": { "h": 8, "w": 16, "x": 8, "y": 12 },
      "datasource": { "type": "loki", "uid": "grafanacloud-logs" },
      "targets": [
        {
          "expr": "topk(10, sum by (rule) (count_over_time({source_type=\"falco\"} | json | rule != \"\" [$__range])))",
          "legendFormat": "{{rule}}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Top Triggered Rules — Detail",
      "type": "table",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 20 },
      "datasource": { "type": "loki", "uid": "grafanacloud-logs" },
      "targets": [
        {
          "expr": "topk(15, sum by (rule, priority) (count_over_time({source_type=\"falco\"} | json | rule != \"\" [$__range])))",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Recent Falco Alerts (Live Tail)",
      "type": "logs",
      "gridPos": { "h": 12, "w": 24, "x": 0, "y": 30 },
      "datasource": { "type": "loki", "uid": "grafanacloud-logs" },
      "targets": [
        {
          "expr": "{source_type=\"falco\"} | json",
          "refId": "A"
        }
      ],
      "options": {
        "showTime": true,
        "showLabels": true,
        "showCommonLabels": false,
        "wrapLogMessage": true,
        "prettifyLogMessage": true,
        "enableLogDetails": true,
        "sortOrder": "Descending"
      }
    }
  ],
  "schemaVersion": 39,
  "tags": ["falco", "runtime", "security", "kernel"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Falco Security Alerts",
  "uid": "falco-runtime-security",
  "version": 2
}
