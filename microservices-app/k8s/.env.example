# ─── Grafana Cloud Loki credentials (microservices-app/k8s) ─────────────────
# Copy this file to .env and fill in your values:
#   copy .env.example .env
#
# NEVER commit .env — it is listed in .gitignore.
#
# Where to find values (Grafana Cloud portal):
#   Stack → Loki → Details → URL, User (instance ID), Access policy token
#
# Used by:
#   apply-grafana-cloud-secret.ps1  → K8s secret grafana-cloud-loki
#   install-falco.bat               → Falcosidekick Loki output
#   run-project.bat / hotfix-running-cluster.bat
#   audit-service                   → forwards UI resource=falco rows to Grafana
# ─────────────────────────────────────────────────────────────────────────────

# Full push URL (optional; apply-grafana-cloud-secret.ps1 accepts this or LOKI_URL)
LOKI_PUSH_URL=https://logs-prod-XXX.grafana.net/loki/api/v1/push

# Base Loki host — Vector appends /loki/api/v1/push automatically
LOKI_URL=https://logs-prod-XXX.grafana.net

# Numeric instance / user ID for Grafana Cloud Loki basic auth
LOKI_INSTANCE_ID=1234567

# Access policy token with logs:write (starts with glc_)
GRAFANA_CLOUD_TOKEN=glc_YOUR_GRAFANA_CLOUD_TOKEN
